# =============================================================================
# Composer — single source of truth for ALL secrets.
# Copy to .env and fill in. Do not create .env.local / .env.production — this
# one file feeds both local dev (.dev.vars is generated from it) and the
# Cloudflare secret store (npm run secrets uploads every key below).
# =============================================================================

# --- Telegram ---------------------------------------------------------------
# Token from @BotFather for @Composer_ubot.
TELEGRAM_BOT_TOKEN=
# Only needed for the Cloudflare Workers WEBHOOK mode. The temporary polling
# mode (npm start) does not use it. Any random string, e.g. openssl rand -hex 24.
TELEGRAM_WEBHOOK_SECRET=

# --- OpenRouter (the text brain) --------------------------------------------
# API key from https://openrouter.ai/keys
OPENROUTER_API=
# NOTE: OPENROUTER_MODEL is IGNORED — the model is hardcoded as "openrouter/free"
# in src/llm/openrouter.js. Change it there if needed.

# --- GROQ (OPTIONAL — currently DISABLED) -----------------------------------
# Off. Kept in code; only used if you switch providerForTask to "groq" in
# src/llm/models.js. https://console.groq.com/keys
GROQ_API=

# --- Media downloads (our own yt-dlp system) --------------------------------
# Downloads (download_media / download_music) use yt-dlp + ffmpeg directly — no
# API keys and no external service. Both must be installed on the host that runs
# the Node mode (`pip install yt-dlp`, and install ffmpeg). This runs in the
# Node runtime only; the Cloudflare Workers isolate cannot spawn yt-dlp.
# All of the following are OPTIONAL:
#   YTDLP_BIN              path to the yt-dlp binary (default: yt-dlp on PATH)
#   YTDLP_MAX_FILESIZE_MB  skip files larger than this (default: 50, Telegram limit)
#   YTDLP_DEFAULT_HEIGHT   default max video height when none requested (default: 1080)
# On datacenter/cloud IPs YouTube may demand "confirm you're not a bot". Fix it
# with cookies (set ONE): YTDLP_COOKIES = path to a Netscape cookies.txt, or
# YTDLP_COOKIES_FROM_BROWSER = a browser name (chrome/firefox/edge/brave/…).
YTDLP_BIN=
YTDLP_MAX_FILESIZE_MB=
YTDLP_DEFAULT_HEIGHT=
YTDLP_COOKIES=
YTDLP_COOKIES_FROM_BROWSER=

# --- Research / web search --------------------------------------------------
# web_search and deep_research use DuckDuckGo's keyless HTML endpoint — no API
# key required. SEARCH_REGION is optional (DuckDuckGo "kl" code, e.g. ru-ru,
# us-en; default wt-wt = no region).
SEARCH_REGION=
