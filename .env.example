# =============================================================================
# Composer — single source of truth for ALL secrets.
# Copy to .env and fill in. Do not create .env.local / .env.production — this
# one file feeds both local dev (.dev.vars is generated from it) and the
# Cloudflare secret store (npm run secrets uploads every key below).
# =============================================================================

# --- Telegram ---------------------------------------------------------------
# Token from @BotFather for @Composer_ubot.
TELEGRAM_BOT_TOKEN=
# Only needed for the Cloudflare Workers WEBHOOK mode. The temporary polling
# mode (npm start) does not use it. Any random string, e.g. openssl rand -hex 24.
TELEGRAM_WEBHOOK_SECRET=

# --- GROQ (the brain) -------------------------------------------------------
# API key from https://console.groq.com/keys
GROQ_API=
# The underlying model. Treated as a secret so the bot stays model-agnostic and
# never discloses what it runs on — set it in .env, NOT here in version control.
GROQ_MODEL=

# --- Media downloads (Cobalt: YouTube, Instagram, Pinterest, music) ---------
# The Cobalt instance URL is a non-secret and lives in wrangler.toml ([vars]
# COBALT_API_URL) so it is NOT duplicated here. Set only the key, if your
# instance requires one. https://github.com/imputnet/cobalt
COBALT_API_KEY=

# --- Research / web search --------------------------------------------------
# Tavily powers web_search and deep_research. https://tavily.com
TAVILY_API_KEY=
